        local b = tonumber(Refs.BBox.Text);

        if r and g and b then
            Picker:SetHSVFromRGB(Color3.fromRGB(r, g, b));
            Picker:Display();
            Library:RefreshColorPickerUI();
            return;
        end;

        local hex = Refs.HexBox.Text:gsub('#', '');
        local success, color = pcall(Color3.fromHex, hex);
        if success and typeof(color) == 'Color3' then
            Picker:SetHSVFromRGB(color);
            Picker:Display();
            Library:RefreshColorPickerUI();
        end;
    end;

    for _, Box in next, { Refs.RBox, Refs.GBox, Refs.BBox, Refs.HexBox } do
        Box.FocusLost:Connect(function(enter)
            if enter then
                ApplyInputColor();
                Library:AttemptSave();
