    end);

    ResizeHolder.MouseLeave:Connect(function()
        ResizeCircle.BackgroundTransparency = 0.55;
        ResizeCircle.BackgroundColor3 = Library.AccentColor;
    end);

    ResizeHolder.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return;
        end;

        local StartSize = Outer.Size;
        local StartMouse = Vector2.new(Mouse.X, Mouse.Y);

        while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            local Delta = Vector2.new(Mouse.X, Mouse.Y) - StartMouse;

            Outer.Size = UDim2.fromOffset(
                math.max(MinSize.X, StartSize.X.Offset + Delta.X),
                math.max(MinSize.Y, StartSize.Y.Offset + Delta.Y)
            );

            if Library.WindowHolder == Outer then
                Library:PositionColorPicker();
            end;

            RenderStepped:Wait();
        end;
    end);
end;

