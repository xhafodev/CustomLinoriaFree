local RainbowStep = 0
local Hue = 0

table.insert(Library.Signals, RenderStepped:Connect(function(Delta)
    RainbowStep = RainbowStep + Delta

    if RainbowStep >= (1 / 60) then
        RainbowStep = 0

        Hue = Hue + (1 / 400);

        if Hue > 1 then
            Hue = 0;
        end;

        Library.CurrentRainbowHue = Hue;
        Library.CurrentRainbowColor = Color3.fromHSV(Hue, 0.8, 1);
    end

    Library.GradientCycle = Library.GradientCycle + Delta;

    if Library.ScrollGradient then
        Library.ScrollGradient.Offset = Vector2.new((Library.GradientCycle % 2) / 2, 0);
    end
end))

