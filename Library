function Library:SetWatermark(Text)
    if not Library.Watermark or not Library.WatermarkText then
        return;
    end;

    Library.WatermarkText.RichText = true;
    local PlainText = Text:gsub('<[^>]+>', '');
    local X = Library:GetTextBounds(PlainText, nil, 14);
    Library.Watermark.Size = UDim2.fromOffset(math.max(X + 16, 260), 24);
    Library.WatermarkText.Text = Text;
end;

function Library:StartWatermark()
    if Library.WatermarkConnection then
        Library:SetWatermarkVisibility(true);
        return;
    end;

    Library.WatermarkFPSCount = 0;
    Library.WatermarkFPSTimer = 0;
    Library.WatermarkFPS = 0;

    Library.WatermarkConnection = RunService.Heartbeat:Connect(function(Delta)
        if not Library.WatermarkText then
            return;
        end;

        Library.WatermarkFPSCount = Library.WatermarkFPSCount + 1;
        Library.WatermarkFPSTimer = Library.WatermarkFPSTimer + Delta;

        if Library.WatermarkFPSTimer >= 0.5 then
            Library.WatermarkFPS = math.floor(Library.WatermarkFPSCount / Library.WatermarkFPSTimer);
            Library.WatermarkFPSCount = 0;
            Library.WatermarkFPSTimer = 0;
        end;

        local TimeText = os.date('%H:%M:%S');
        local UID = LocalPlayer.UserId;
        local Text = string.format(
            '<font color="rgb(255,255,255)">chad</font><font color="rgb(255,119,68)">vision</font> | %d FPS | %s | %d',
            Library.WatermarkFPS,
            TimeText,
            UID
        );

        Library:SetWatermark(Text);
    end);

    table.insert(Library.Signals, Library.WatermarkConnection);
    Library:SetWatermarkVisibility(true);
end;

