function Library:Create(Class, Properties)
    local _Instance = Class;

    if type(Class) == 'string' then
        _Instance = Instance.new(Class);
    end;

    for Property, Value in next, Properties do
        _Instance[Property] = Value;
    end;

    return _Instance;
end;

function Library:GetFontFace()
    local Entry = FontCatalog[Library.FontName or 'Montserrat'] or FontCatalog.Montserrat;
    local Success, Face = pcall(Entry.Build);

    if Success and Face then
        return Face;
    end;

    return Font.fromEnum(Enum.Font.Code);
end;

function Library:GetLegacyFont()
    local Entry = FontCatalog[Library.FontName or 'Montserrat'] or FontCatalog.Montserrat;
    return Entry.Legacy or Enum.Font.Code;
end;

function Library:ApplyFontToInstance(Instance)
    if not Instance or (not Instance:IsA('TextLabel') and not Instance:IsA('TextButton') and not Instance:IsA('TextBox')) then
        return;
    end;

    local FontFace = Library:GetFontFace();

    pcall(function()
        Instance.FontFace = FontFace;
    end);

    pcall(function()
        Instance.Font = Library:GetLegacyFont();
    end);
end;

function Library:RegisterFontObject(Instance)
    table.insert(Library.FontRegistry, Instance);
    Library:ApplyFontToInstance(Instance);
end;

function Library:SetFont(FontName)
    Library.FontName = FontName;

    for _, Object in next, Library.FontRegistry do
        if Object and Object.Parent then
            Library:ApplyFontToInstance(Object);
        end;
    end;
end;

