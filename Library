        local Container = Groupbox.Container;

        local NameWidth = Library:GetTextBounds(Info.Text, Enum.Font.Code, 14) + 2;
        local ValueWidth = Library:GetTextBounds(tostring(Info.Default), Enum.Font.Code, 14) + 4;
        local PrefixWidth = NameWidth + ValueWidth + 2;

        local SliderRow = Library:Create('Frame', {
            BackgroundTransparency = 1;
            Size = UDim2.new(1, -4, 0, 18);
            ZIndex = 5;
            Parent = Container;
        });

        local NameLabel = Library:CreateLabel({
