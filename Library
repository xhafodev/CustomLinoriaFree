function Library:GetDragTargetSize(Instance)
    local Abs = Instance.AbsoluteSize;
    local Width = Abs.X;
    local Height = Abs.Y;

    if Width < 2 then
        Width = Instance.Size.X.Offset;

        if Instance.Size.X.Scale > 0 then
            Width = (ScreenGui.AbsoluteSize.X * Instance.Size.X.Scale) + Instance.Size.X.Offset;
        end;
    end;

    if Height < 2 then
        Height = Instance.Size.Y.Offset;

        if Instance.Size.Y.Scale > 0 then
            Height = (ScreenGui.AbsoluteSize.Y * Instance.Size.Y.Scale) + Instance.Size.Y.Offset;
        end;
    end;

    return math.max(Width, 2), math.max(Height, 2);
end;

