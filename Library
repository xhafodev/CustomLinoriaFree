    function Window:RefreshTabLayout()
        local Count = #self.TabOrder;
        if Count == 0 then
            return;
        end;

        local Gap = 4;
        local TotalWidth = TabButtons.AbsoluteSize.X;
        local Height = TabButtons.AbsoluteSize.Y;

        if TotalWidth <= 0 then
            task.defer(function()
                self:RefreshTabLayout();
            end);
            return;
        end;

        local TabWidth = math.floor((TotalWidth - Gap * (Count - 1)) / Count);
        local Remainder = TotalWidth - (TabWidth * Count + Gap * (Count - 1));

        for Index, Tab in ipairs(self.TabOrder) do
            local Width = TabWidth + (Index == Count and Remainder or 0);
            local X = (Index - 1) * (TabWidth + Gap);

            Tab.TabButton.Size = UDim2.fromOffset(Width, Height);
            Tab.TabButton.Position = UDim2.fromOffset(X, 0);
            Tab.TabButtonLabel.TextXAlignment = Enum.TextXAlignment.Center;
        end;
    end;

