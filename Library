    function Library.Toggle()
        Outer.Visible = not Outer.Visible;
        ModalElement.Modal = Outer.Visible;

        if not Outer.Visible then
            Library:HideColorPicker();
        end

        local oIcon = Mouse.Icon;
        local State = InputService.MouseIconEnabled;

        local Cursor = Drawing.new('Triangle');
        Cursor.Thickness = 1;
        Cursor.Filled = true;

        while Outer.Visible do
            local mPos = Workspace.CurrentCamera:WorldToViewportPoint(Mouse.Hit.p);

            Cursor.Color = Library.AccentColor;
            Cursor.PointA = Vector2.new(mPos.X, mPos.Y);
            Cursor.PointB = Vector2.new(mPos.X, mPos.Y) + Vector2.new(6, 14);
            Cursor.PointC = Vector2.new(mPos.X, mPos.Y) + Vector2.new(-6, 14);

            Cursor.Visible = not InputService.MouseIconEnabled;

            RenderStepped:Wait();
        end;

        Cursor:Remove();
    end

    Library:GiveSignal(InputService.InputBegan:Connect(function(Input, Processed)
        if type(Library.ToggleKeybind) == 'table' and Library.ToggleKeybind.Type == 'KeyPicker' then
            if Input.UserInputType == Enum.UserInputType.Keyboard and Input.KeyCode.Name == Library.ToggleKeybind.Value then
                task.spawn(Library.Toggle)
            end
        elseif Input.KeyCode == Enum.KeyCode.RightControl or (Input.KeyCode == Enum.KeyCode.RightShift and (not Processed)) then
            task.spawn(Library.Toggle)
        end

        if Input:IsModifierKeyDown(Enum.ModifierKey.Ctrl) and Outer.Visible then
            local HoveringColorPicker = Library.ActiveColorPicker

            if not HoveringColorPicker then
                for i, colorPicker in next, Options do
                    if colorPicker.Type == 'ColorPicker' then
                        local displayFrame = colorPicker.DisplayFrame
                        local tabFrame = displayFrame and displayFrame:FindFirstAncestor('TabFrame')

                        if tabFrame and tabFrame.Visible and Library:IsMouseOverFrame(colorPicker.DisplayFrame) then
                            HoveringColorPicker = colorPicker
                            break
                        end
                    end
                end
            end

            if not HoveringColorPicker then
                return
            end

            if Input.KeyCode == Enum.KeyCode.C then
                Library.ColorClipboard = HoveringColorPicker.Value
                Library:Notify('Copied color', 2)
            elseif Input.KeyCode == Enum.KeyCode.V and Library.ColorClipboard then
                HoveringColorPicker:SetValueRGB(Library.ColorClipboard)
                if Library.ActiveColorPicker == HoveringColorPicker then
                    Library:RefreshColorPickerUI()
                end
            end
        end
    end))

    if Config.AutoShow then task.spawn(Library.Toggle) end

    Window.Holder = Outer;
    Library.WindowHolder = Outer;

    Library:StartWatermark();
    Library.Watermark.Position = UDim2.new(0, 12, 0, 12);

    return Window;
end;

function Library:EnsureLuaFolder()
    if typeof(makefolder) ~= 'function' then
        return;
    end;

    if typeof(isfolder) == 'function' and not isfolder(Library.LuaFolder) then
        makefolder(Library.LuaFolder);
    end;
end;

function Library:SanitizeScriptName(Name)
    Name = tostring(Name or ''):gsub('[^%w%-_ ]', ''):gsub('^%s+', ''):gsub('%s+$', '');

    if Name == '' then
        Name = 'script';
    end;

    return Name;
end;

function Library:ListLuaScripts()
    Library:EnsureLuaFolder();

    if typeof(listfiles) ~= 'function' then
        return {};
    end;

    local Scripts = {};

    for _, Path in next, listfiles(Library.LuaFolder) do
        if Path:sub(-4) == '.lua' then
            local Name = Path:match('([^/\\]+)%.lua$');

            if Name then
                table.insert(Scripts, Name);
            end;
        end;
    end;

    table.sort(Scripts);

    return Scripts;
end;

function Library:SaveLuaScript(Name, Source)
    if typeof(writefile) ~= 'function' then
        Library:Notify('writefile is unavailable in this executor', 3);
        return false;
    end;

    Name = Library:SanitizeScriptName(Name);
    Library:EnsureLuaFolder();
    writefile(Library.LuaFolder .. '/' .. Name .. '.lua', Source);
    return true;
end;

function Library:LoadLuaScript(Name)
    if typeof(readfile) ~= 'function' or typeof(isfile) ~= 'function' then
        return nil;
    end;

    local Path = Library.LuaFolder .. '/' .. Name .. '.lua';

    if not isfile(Path) then
        return nil;
    end;

    return readfile(Path);
end;

function Library:DeleteLuaScript(Name)
    if typeof(delfile) ~= 'function' or typeof(isfile) ~= 'function' then
        return false;
    end;

    local Path = Library.LuaFolder .. '/' .. Name .. '.lua';

    if isfile(Path) then
        delfile(Path);
        return true;
    end;

    return false;
end;

function Library:RefreshLuaScriptList()
    if not Options.LuaScriptList then
        return;
    end;

    local Scripts = Library:ListLuaScripts();
    Options.LuaScriptList:SetValues(Scripts);

    if Scripts[1] then
        Options.LuaScriptList:SetValue(Scripts[1]);
    else
        Options.LuaScriptList:SetValue(nil);
    end;
end;

function Library:ExecuteLua(Source, ScriptName)
    ScriptName = ScriptName or '@ChadvisionLua';

    if type(Source) ~= 'string' or Source:gsub('%s', '') == '' then
        Library:Notify('No Lua source to execute', 3);
        return false, 'empty source';
    end;

    local WrappedSource = [[
local __CV_OLD_PRINT = print
print = function(...)
    local Count = select('#', ...)
    local Parts = {}
    for Index = 1, Count do
        Parts[Index] = tostring(select(Index, ...))
    end
    local Message = table.concat(Parts, '\t')
    if getgenv().Library and getgenv().Library.Notify then
        getgenv().Library:Notify(Message, 3)
    end
    return __CV_OLD_PRINT(...)
end
]] .. Source;

    local Function, CompileError = loadstring(WrappedSource, ScriptName);

    if not Function then
        Library:Notify('Compile error: ' .. tostring(CompileError), 4);
        return false, CompileError;
    end;

    local Success, RuntimeError = pcall(Function);

    if not Success then
        Library:Notify('Runtime error: ' .. tostring(RuntimeError), 4);
        return false, RuntimeError;
    end;

    Library:Notify('Script executed successfully', 2);
    return true;
end;

function Library:CreateLuaTab(Tab)
    local EditorSubTab = Tab:AddSubTab('Editor');
    local EditorGroup = EditorSubTab:AddFullGroupbox('Lua Environment');

    EditorGroup:AddInput('LuaScriptName', {
        Text = 'Script name';
        Default = 'MyScript';
        Finished = true;
    });

    local CodeEditor = EditorGroup:AddCodeEditor({
        Text = 'Lua source';
        Default = 'print("hello world")';
        Placeholder = 'print("hello world")';
        Height = 300;
    });

    Library.LuaCodeEditor = CodeEditor;
    Library.LuaEditorSubTab = EditorSubTab;

    EditorGroup:AddButton('Execute Lua', function()
        Library:ExecuteLua(CodeEditor:GetValue(), Options.LuaScriptName.Value);
    end):AddButton('Save Lua', function()
        if Library:SaveLuaScript(Options.LuaScriptName.Value, CodeEditor:GetValue()) then
            Library:Notify('Saved script: ' .. Options.LuaScriptName.Value, 2);
            Library:RefreshLuaScriptList();
        end;
    end);

    EditorGroup:AddButton('Clear Editor', function()
        CodeEditor:SetValue('');
    end);

    local ScriptsSubTab = Tab:AddSubTab('Scripts');
    local ScriptsGroup = ScriptsSubTab:AddLeftGroupbox('Saved Scripts');
    local InitialScripts = Library:ListLuaScripts();

    ScriptsGroup:AddDropdown('LuaScriptList', {
        Text = 'Saved scripts';
        Values = InitialScripts;
        AllowNull = true;
        Default = InitialScripts[1];
    });

    ScriptsGroup:AddButton('Refresh List', function()
        Library:RefreshLuaScriptList();
    end);

    ScriptsGroup:AddButton('Load Script', function()
        local Name = Options.LuaScriptList.Value;

        if not Name or Name == '' then
            Library:Notify('Select a saved script first', 3);
            return;
        end;

        local Source = Library:LoadLuaScript(Name);

        if not Source then
            Library:Notify('Could not load script: ' .. tostring(Name), 3);
            return;
        end;

        CodeEditor:SetValue(Source);
        Options.LuaScriptName:SetValue(Name);
        EditorSubTab:Show();
        Library:Notify('Loaded ' .. Name .. ' into editor', 2);
    end):AddButton('Execute Script', function()
        local Name = Options.LuaScriptList.Value;

        if not Name or Name == '' then
            Library:Notify('Select a saved script first', 3);
            return;
        end;

        local Source = Library:LoadLuaScript(Name);

        if not Source then
            Library:Notify('Could not load script: ' .. tostring(Name), 3);
            return;
        end;

        Library:ExecuteLua(Source, Name);
    end);

    ScriptsGroup:AddButton('Delete Script', function()
        local Name = Options.LuaScriptList.Value;

        if not Name or Name == '' then
            Library:Notify('Select a saved script first', 3);
            return;
        end;

        if Library:DeleteLuaScript(Name) then
            Library:Notify('Deleted script: ' .. Name, 2);
            Library:RefreshLuaScriptList();
        else
            Library:Notify('Could not delete script: ' .. Name, 3);
        end;
    end);

    local PreviewGroup = ScriptsSubTab:AddMiddleGroupbox('Preview');
    local PreviewEditor = PreviewGroup:AddCodeEditor({
        Text = 'Selected script';
        Default = '';
        Placeholder = 'Load a script to preview it here';
        Height = 300;
    });

    PreviewEditor.Box.TextEditable = false;

    Options.LuaScriptList:OnChanged(function()
        local Name = Options.LuaScriptList.Value;
        local Source = Name and Library:LoadLuaScript(Name) or '';
        PreviewEditor:SetValue(Source or '');
    end);

    return {
        Editor = CodeEditor;
        EditorSubTab = EditorSubTab;
        ScriptsSubTab = ScriptsSubTab;
        Preview = PreviewEditor;
    };
end;

getgenv().Library = Library;

return Library;
