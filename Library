function Library:MakeGhostDraggable(Instance, DragHandle)
    DragHandle = DragHandle or Instance;
    DragHandle.Active = true;

    DragHandle.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return;
        end;

        if Library:MouseIsOverOpenedFrame() then
            return;
        end;

        local Ghost = Library:CreateDragGhost();
        local MouseX, MouseY = Library:GetMousePosition();
        local StartTopLeft = Instance.AbsolutePosition;
        local ObjPos = Vector2.new(
            MouseX - StartTopLeft.X,
            MouseY - StartTopLeft.Y
        );

        local function UpdateGhost()
            local Width, Height = Library:GetDragTargetSize(Instance);
            MouseX, MouseY = Library:GetMousePosition();

            Ghost.AnchorPoint = Vector2.new(0, 0);
            Ghost.Size = UDim2.fromOffset(Width, Height);
            Ghost.Position = UDim2.fromOffset(
                MouseX - ObjPos.X,
                MouseY - ObjPos.Y
            );
        end;

        UpdateGhost();
        Ghost.Visible = true;
        task.defer(UpdateGhost);

        while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            UpdateGhost();
            RenderStepped:Wait();
        end;

        local NewTopLeft = Ghost.AbsolutePosition;
        local Width, Height = Library:GetDragTargetSize(Instance);

        Instance.Position = UDim2.fromOffset(
            NewTopLeft.X + (Width * Instance.AnchorPoint.X),
            NewTopLeft.Y + (Height * Instance.AnchorPoint.Y)
        );

        Ghost:Destroy();

        if Library.WindowHolder == Instance then
            Library:PositionColorPicker();
        end;
    end);
end;

function Library:MakeDraggable(Instance, DragHandle)
    Library:MakeGhostDraggable(Instance, DragHandle);
end;

function Library:MakeWindowDraggable(Outer, DragHandle)
    Library:MakeGhostDraggable(Outer, DragHandle);
end;

